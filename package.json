{
  "name": "flash-api-sdk",
  "version": "1.0.2",
  "description": "SDK JavaScript oficial da Flash API - Multi-sessão WhatsApp",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "build": "node scripts/build.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "prettier --check src/",
    "format": "prettier --write src/",
    "docs": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "prepublish": "npm run build && npm run test"
  },
  "keywords": [
    "whatsapp",
    "api",
    "sdk",
    "javascript",
    "baileys",
    "chat",
    "automation",
    "messages",
    "webhook",
    "websocket"
  ],
  "author": "Flash API",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clsshbr2/flash-api-sdk"
  },
  "bugs": {
    "url": "https://github.com/clsshbr2/flash-api-sdk/issues"
  },
  "homepage": "https://github.com/clsshbr2/flash-api-sdk",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "events": "^3.3.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.0.0",
    "esbuild": "^0.19.0",
    "prettier": "^3.1.0",
    "vitepress": "^1.0.0",
    "vitest": "^1.0.0"
  }
}